generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int      @id @default(autoincrement())
  name            String
  username        String   @unique
  password        String
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  description     String?
  location        String?
  profileImageUrl String?  @map("profile_image_url")
  url             String?
  followers       User[]   @relation("UserFollows")
  following       User[]   @relation("UserFollows")
  pinnedPost      Post?    @relation("PinnedPost")
  posts           Post[]   @relation("AuthoredPost")
  likes           Post[]   @relation("LikedPost")
  bookmarks       Post[]   @relation("BookmarkedPost")

  @@map("users")
}

model Post {
  id               Int                @id @default(autoincrement())
  text             String?
  attachment       String?
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  author           User               @relation("AuthoredPost", fields: [authorId], references: [id])
  authorId         Int                @map("author_id")
  pinnedBy         User?              @relation("PinnedPost", fields: [pinnedById], references: [id])
  pinnedById       Int?               @unique @map("pinned_by_id")
  conversationId   Int                @map("conversation_id")
  conversation     Post               @relation("ConversationThread", fields: [conversationId], references: [id])
  thread           Post[]             @relation("ConversationThread")
  referencedPostId Int?               @map("referenced_post_id")
  referencedPost   Post?              @relation("PostReferences", fields: [referencedPostId], references: [id])
  referencedBy     Post[]             @relation("PostReferences")
  referenceType    PostReferenceType?
  likes            User[]             @relation("LikedPost")
  bookmarks        User[]             @relation("BookmarkedPost")

  @@map("posts")
}

enum PostReferenceType {
  REPLY
  REPOST
  QUOTE
}
